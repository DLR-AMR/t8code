/** \file t8_test_data_dir.h.in 
 * This header defines the macro T8_TEST_DATA_DIR, which specifies the path to the test data directory.
 * The value is substituted by CMake during the build configuration process. 
 * This creates the file t8_test_data_dir.h in the build directory,
 * which can be included in test source files to access the test data directory path.
 *
 * Usage:
 * #include "t8_test_data_dir.h"
 * std::string data_dir = T8_TEST_DATA_DIR;
 */

#pragma once

#define T8_TEST_DATA_DIR "@T8_TEST_DATA_DIR@"